---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, emergencyPhone } from '../data/business';

const title = 'About EnviroPro USA · 36 Years Restoring South Florida Homes';
const description = 'Family-owned restoration company serving Miami-Dade, Broward and Orlando since 1990. IICRC certified, bilingual, insurance-approved. Meet the team behind EnviroPro.';

const milestones = [
  { year: '1990', label: 'Founded in Miami by Rafael Salazar' },
  { year: '2005', label: 'Expanded to Broward County' },
  { year: '2012', label: 'Orlando metro service launched' },
  { year: '2018', label: 'Impact Windows division added' },
  { year: '2026', label: '36 years and counting — over 10,000 homes restored' }, // TODO: confirmar cifra con cliente
];

const values = [
  { icon: '⚡', title: 'Immediate Response', desc: '24/7 dispatch, 365 days. Most calls answered within 60 minutes.' },
  { icon: '🛡️', title: 'Insurance Direct Billing', desc: 'We coordinate with your adjuster — no out-of-pocket for covered claims.' },
  { icon: '🌎', title: 'Bilingual From Day One', desc: 'English and Spanish, every call. Miami deserves nothing less.' },
  { icon: '🏅', title: 'IICRC Certified', desc: 'Every technician trained to industry standards in water, fire, and mold.' },
];
---

<BaseLayout title={title} description={description} lang="en" pathname="/about">

  <!-- HERO ABOUT -->
  <section class="bg-[var(--color-ink)] text-white">
    <div class="container-x py-20 lg:py-28">
      <p class="text-sm uppercase tracking-widest font-semibold mb-4" style="color: var(--color-accent)">Since 1990</p>
      <h1 class="text-4xl lg:text-6xl font-bold mb-6" style="font-family: var(--font-display)">
        Family-owned.<br/>
        <span style="color: var(--color-emergency)">South Florida tested.</span>
      </h1>
      <p class="text-xl opacity-80 max-w-2xl leading-relaxed">
        For 36 years, the Salazar family has been the call South Florida homeowners make when water,
        mold, fire, or hurricanes strike. We built this company on one promise: show up, fix it right,
        treat every home like it's our own.
      </p>
    </div>
  </section>

  <!-- FOUNDER STORY -->
  <section class="section-y bg-white">
    <div class="container-x grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
      <div class="lg:col-span-2">
        <div class="aspect-square bg-[var(--color-surface-alt)] rounded-2xl flex items-center justify-center">
          <!-- TODO: foto real de Rafael Salazar -->
          <span class="text-sm" style="color: var(--color-ink-soft)">[Founder photo]</span>
        </div>
      </div>
      <div class="lg:col-span-3">
        <h2 class="text-3xl lg:text-4xl font-bold mb-6" style="font-family: var(--font-display)">
          The Salazar family story
        </h2>
        <div class="space-y-4 text-lg" style="color: var(--color-ink-soft)">
          <p>
            Rafael Salazar founded EnviroPro USA in 1990 with a simple observation: South Florida homeowners
            were getting let down by restoration contractors who showed up late, didn't speak their language,
            or disappeared after the deposit.
          </p>
          <p>
            Three decades later, Rafael still answers emergency calls. His son Andrew runs day-to-day operations.
            The team has grown to dozens of certified technicians across Miami-Dade, Broward, and Orlando — but
            the standard hasn't changed: we answer the phone, we show up fast, and we leave the home better
            than we found it.
          </p>
          <p class="font-semibold" style="color: var(--color-ink)">
            36 years. Same family. Same promise.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES GRID -->
  <section class="section-y" style="background: var(--color-surface-alt)">
    <div class="container-x">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-5xl font-bold mb-4" style="font-family: var(--font-display)">
          What sets us apart
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {values.map((v) => (
          <div class="bg-white p-7 rounded-2xl shadow-sm">
            <div class="text-3xl mb-3">{v.icon}</div>
            <h3 class="font-bold text-xl mb-2">{v.title}</h3>
            <p style="color: var(--color-ink-soft)">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="section-y bg-white">
    <div class="container-x max-w-3xl">
      <h2 class="text-3xl lg:text-5xl font-bold mb-12 text-center" style="font-family: var(--font-display)">
        Our story by year
      </h2>
      <div class="space-y-6">
        {milestones.map((m) => (
          <div class="flex gap-6 items-start border-l-2 border-[var(--color-emergency)] pl-6 py-2">
            <span class="text-2xl font-bold min-w-[80px]" style="color: var(--color-trust); font-family: var(--font-display)">
              {m.year}
            </span>
            <p class="text-lg pt-1">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS STRIP -->
  <section class="py-12 bg-white border-t border-[var(--color-border)]">
    <div class="container-x text-center">
      <p class="text-sm uppercase tracking-widest mb-6" style="color: var(--color-ink-soft)">
        Licensed · Insured · Certified
      </p>
      <div class="flex flex-wrap justify-center gap-8 items-center">
        {business.certifications.map((cert) => (
          <span class="px-5 py-3 bg-[var(--color-surface-alt)] rounded-lg font-semibold text-sm">
            {cert}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section-y bg-[var(--color-ink)] text-white text-center">
    <div class="container-x">
      <h2 class="text-3xl lg:text-5xl font-bold mb-4" style="font-family: var(--font-display)">
        Ready when you need us.
      </h2>
      <p class="text-lg opacity-80 mb-8">Emergency or scheduled service — same promise, same family.</p>
      <a href={`tel:${emergencyPhone.e164}`} class="btn-emergency text-xl">
        Call {emergencyPhone.display}
      </a>
    </div>
  </section>
</BaseLayout>
