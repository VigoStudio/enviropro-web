---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, emergencyPhone } from '../data/business';

const title = 'EnviroPro USA · 24/7 Water, Mold & Fire Damage Restoration · Miami-Dade';
const description = "South Florida's trusted restoration experts for 36 years. Water damage, mold removal, fire restoration, hurricane response. 24/7 emergency service in Miami-Dade, Broward & Orlando.";

const featuredService = {
  num: '01',
  title: 'Water Damage Restoration',
  href: '/services/water-damage',
  desc: 'Pipe bursts, flooding, storm water. The clock starts the moment water enters your property. We aim to be on-site in under 60 minutes.',
  steps: ['Emergency dispatch', 'Water extraction', 'Structural drying', 'Full restoration'],
};

const secondaryServices = [
  { num: '02', title: 'Mold Removal', desc: 'IICRC-certified inspection, containment, and remediation.', href: '/services/mold-removal' },
  { num: '03', title: 'Fire & Smoke', desc: 'Full restoration and direct insurance coordination.', href: '/services/fire-damage' },
  { num: '04', title: 'Hurricane Response', desc: 'Roof tarping, water extraction, mold prevention.', href: '/services/hurricane-emergency' },
  { num: '05', title: 'Impact Windows', desc: 'Hurricane-rated installation, insurance discounts.', href: '/services/impact-windows' },
];

const credentials = [
  'IICRC Certified',
  'Insurance Direct Billing',
  'Licensed & Insured',
  'Bilingual Team',
];

const trustPoints = [
  { label: '36 years', sub: 'Serving South Florida since 1990' },
  { label: 'IICRC', sub: 'Certified technicians on every project' },
  { label: 'Insurance', sub: 'Direct billing — no out-of-pocket for covered claims' },
  { label: 'Bilingual', sub: 'English & Spanish, native-level service' },
];
---

<BaseLayout title={title} description={description} lang="en" pathname="/">

  <!-- ===================================================
       HERO
       =================================================== -->
  <section
    class="relative overflow-hidden text-white"
    style="background: #0A0A0A; min-height: 88vh; display: flex; align-items: center;"
  >
    <!-- Background video -->
    <video
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      preload="auto"
    >
      <source src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260306_074215_04640ca7-042c-45d6-bb56-58b1e8a42489.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay so text stays readable -->
    <div
      class="absolute inset-0 pointer-events-none"
      aria-hidden="true"
      style="background: linear-gradient(135deg, rgba(8,8,8,0.82) 0%, rgba(12,23,48,0.72) 55%, rgba(8,8,8,0.82) 100%);"
    ></div>

    <div class="container-x relative w-full">
      <div class="max-w-4xl py-24 lg:py-36">

        <!-- Eyebrow label -->
        <p
          class="gsap-fade-in flex items-center gap-2 text-xs uppercase font-semibold mb-6"
          style="color: var(--color-accent); letter-spacing: 0.08em;"
        >
          <span class="inline-block w-6 h-px" style="background: var(--color-accent);" aria-hidden="true"></span>
          24/7 Emergency Response · 36 Years in South Florida
        </p>

        <!-- H1: single display instance per page -->
        <h1
          class="gsap-fade-in font-extrabold mb-6"
          style="font-size: var(--text-display); font-family: var(--font-display); letter-spacing: -0.02em; line-height: 1.08;"
        >
          When disaster strikes,<br />
          <span style="color: var(--color-emergency);">we're already on the way.</span>
        </h1>

        <!-- Sub-copy -->
        <p
          class="gsap-fade-in text-lg leading-relaxed mb-8 max-w-2xl"
          style="color: rgba(255,255,255,0.72);"
        >
          Water damage, mold removal, fire restoration, hurricane response.
          IICRC certified. Insurance direct billing.
          Bilingual team across Miami-Dade, Broward and Orlando.
        </p>

        <!-- CTAs: red = call now, navy = schedule -->
        <div class="gsap-fade-in flex flex-col sm:flex-row gap-3 mb-10">
          <a href={`tel:${emergencyPhone.e164}`} class="btn-emergency gsap-pulse text-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call {emergencyPhone.display}
          </a>
          <a href="/contact" class="btn-trust text-lg">Book Free Inspection</a>
        </div>

        <!-- Credential strip: inline, small -->
        <ul
          class="gsap-stagger flex flex-wrap gap-x-6 gap-y-2"
          aria-label="Certifications"
        >
          {credentials.map((c) => (
            <li
              class="flex items-center gap-1.5 text-sm opacity-0"
              style="color: rgba(255,255,255,0.5);"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7l3.5 3.5 6.5-6.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {c}
            </li>
          ))}
        </ul>

      </div>
    </div>
  </section>

  <!-- ===================================================
       SERVICES BENTO
       Varied grid: featured (spans 2 rows) + 2×2 secondary
       Breaks identical-card-grid pattern.
       =================================================== -->
  <section class="section-y bg-white">
    <div class="container-x">

      <!-- Section header with "view all" link -->
      <div class="flex items-end justify-between mb-10 flex-wrap gap-4">
        <h2
          class="text-3xl lg:text-5xl font-bold leading-tight"
          style="font-family: var(--font-display); letter-spacing: -0.02em;"
        >
          Restoration<br class="hidden lg:block" /> Services
        </h2>
        <a
          href="/services"
          class="text-sm font-semibold flex items-center gap-1.5 hover:underline"
          style="color: var(--color-trust);"
        >
          View all services
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">

        <!-- Featured: Water Damage (spans 2 rows on lg) -->
        <article
          class="sm:col-span-2 lg:col-span-1 lg:row-span-2 flex flex-col justify-between p-8 rounded-2xl overflow-hidden relative"
          style="background: var(--color-trust); color: white; min-height: 22rem;"
        >
          <div>
            <p
              class="text-xs font-bold mb-5"
              style="letter-spacing: 0.08em; color: rgba(255,255,255,0.4);"
            >{featuredService.num}</p>

            <h3
              class="text-2xl lg:text-3xl font-bold mb-4 leading-tight"
              style="font-family: var(--font-display); letter-spacing: -0.02em;"
            >{featuredService.title}</h3>

            <p
              class="text-base leading-relaxed mb-6"
              style="color: rgba(255,255,255,0.75);"
            >{featuredService.desc}</p>

            <ol class="space-y-2.5 mb-8">
              {featuredService.steps.map((step, i) => (
                <li class="flex items-center gap-3 text-sm" style="color: rgba(255,255,255,0.8);">
                  <span
                    class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0"
                    style="background: rgba(255,255,255,0.15);"
                  >{i + 1}</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>

          <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
            <a
              href={`tel:${emergencyPhone.e164}`}
              class="btn-emergency w-full justify-center text-sm"
              aria-label={`Call EnviroPro emergency line: ${emergencyPhone.display}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              Call {emergencyPhone.display}
            </a>
            <a
              href={featuredService.href}
              class="text-sm font-semibold text-center py-3 px-4 rounded-[var(--radius-btn)] transition-colors"
              style="background: rgba(255,255,255,0.12); color: white;"
            >
              Full details →
            </a>
          </div>
        </article>

        <!-- Secondary services: numbered, bordered -->
        {secondaryServices.map((s) => (
          <a
            href={s.href}
            class="group flex flex-col justify-between p-6 rounded-2xl transition-all hover:shadow-lg"
            style="border: 1px solid var(--color-border); background: var(--color-surface);"
          >
            <div>
              <p
                class="text-xs font-bold mb-4"
                style="color: var(--color-accent); letter-spacing: 0.08em;"
              >{s.num}</p>
              <h3
                class="text-lg font-bold mb-2 leading-snug"
                style="font-family: var(--font-display); letter-spacing: -0.01em;"
              >{s.title}</h3>
              <p
                class="text-sm leading-relaxed"
                style="color: var(--color-ink-soft);"
              >{s.desc}</p>
            </div>
            <p
              class="mt-5 text-sm font-semibold flex items-center gap-1.5 transition-all"
              style="color: var(--color-trust);"
            >
              Learn more
              <svg
                width="14" height="14" viewBox="0 0 14 14" fill="none"
                aria-hidden="true"
                class="transition-transform group-hover:translate-x-0.5"
              >
                <path d="M2.5 7h9M8 3.5l3.5 3.5-3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================================================
       TRUST — TESTIMONIAL
       Committed navy section: color carries the section.
       =================================================== -->
  <section class="section-y" style="background: var(--color-trust); color: white;">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

        <!-- Left: large testimonial -->
        <div class="lg:col-span-7">
          <p
            class="text-xs uppercase font-semibold mb-6"
            style="letter-spacing: 0.08em; color: rgba(255,255,255,0.5);"
          >What our customers say</p>

          <blockquote
            class="text-2xl lg:text-3xl font-medium leading-snug mb-8"
            style="font-family: var(--font-display); letter-spacing: -0.01em;"
          >
            "EnviroPro responded within an hour after our pipe burst. Professional,
            bilingual, and worked directly with our insurance. Highly recommended."
          </blockquote>

          <div>
            <p class="font-semibold">Mellissa Clark</p>
            <p class="text-sm" style="color: rgba(255,255,255,0.6);">Pinecrest, FL</p>
          </div>
        </div>

        <!-- Right: credential list + CTA -->
        <div class="lg:col-span-5">
          <ul class="space-y-5 mb-8">
            {trustPoints.map((item) => (
              <li class="flex gap-3 items-start">
                <svg
                  width="18" height="18" viewBox="0 0 18 18" fill="none"
                  aria-hidden="true"
                  class="flex-shrink-0 mt-0.5"
                >
                  <path d="M2.5 9l4.5 4.5 8.5-9" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
                </svg>
                <div>
                  <p class="font-bold text-base">{item.label}</p>
                  <p class="text-sm" style="color: rgba(255,255,255,0.7);">{item.sub}</p>
                </div>
              </li>
            ))}
          </ul>

          <a href={`tel:${emergencyPhone.e164}`} class="btn-emergency">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Call Now: {emergencyPhone.display}
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ===================================================
       INSURANCE STRIP
       =================================================== -->
  <section class="section-y" style="background: var(--color-surface-alt);">
    <div class="container-x max-w-3xl text-center">
      <h2
        class="text-3xl lg:text-4xl font-bold mb-4"
        style="font-family: var(--font-display); letter-spacing: -0.02em;"
      >We work directly with your insurance.</h2>
      <p class="text-lg leading-relaxed mb-6" style="color: var(--color-ink-soft);">
        No out-of-pocket cost for covered claims. We coordinate documentation,
        scoping, and direct billing with your adjuster so you can focus on your
        family, not paperwork.
      </p>
      <p class="text-sm font-medium" style="color: var(--color-ink-soft);">
        {business.insurancePartners.join(' · ')}
      </p>
    </div>
  </section>

  <!-- ===================================================
       FINAL CTA
       =================================================== -->
  <section class="section-y text-center" style="background: var(--color-ink); color: white;">
    <div class="container-x">
      <h2
        class="text-3xl lg:text-5xl font-bold mb-4"
        style="font-family: var(--font-display); letter-spacing: -0.02em;"
      >
        Water doesn't wait.<br class="hidden sm:block" /> Neither do we.
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.7);">
        Emergency response across all of South Florida. Call now.
      </p>
      <a href={`tel:${emergencyPhone.e164}`} class="btn-emergency text-xl">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {emergencyPhone.display}
      </a>
    </div>
  </section>

  <!-- ===================================================
       GSAP — disciplined, prefers-reduced-motion respected
       =================================================== -->
  <script>
    import { gsap } from 'gsap';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      document.querySelectorAll<HTMLElement>('.gsap-fade-in, .gsap-stagger li').forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
    } else {
      const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });

      tl.to('.gsap-fade-in', { opacity: 1, duration: 0.8, stagger: 0.15 });
      tl.to('.gsap-stagger li', { opacity: 1, duration: 0.4, stagger: 0.08 }, '-=0.3');

      gsap.to('.gsap-pulse', {
        scale: 1.03,
        duration: 1.2,
        repeat: -1,
        yoyo: true,
        ease: 'power1.inOut',
      });
    }
  </script>

</BaseLayout>
