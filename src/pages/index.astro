---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServicesSection from '../components/ServicesSection.astro';
import Testimonials from '../components/Testimonials.astro';
import { business, emergencyPhone } from '../data/business';

const title = 'EnviroPro USA · 24/7 Water, Mold & Fire Damage Restoration · Miami-Dade';
const description = "South Florida's trusted restoration experts for 36 years. Water damage, mold removal, fire restoration, hurricane response. 24/7 emergency service in Miami-Dade, Broward & Orlando.";

const featured_service = {
  num: '01',
  title: 'Water Damage Restoration',
  href: '/services/water-damage',
  desc: 'Pipe bursts, flooding, storm water. The clock starts the moment water enters your property. We aim to be on-site in under 60 minutes.',
  steps: ['Emergency dispatch', 'Water extraction', 'Structural drying', 'Full restoration'],
};

const secondary_services = [
  { num: '02', title: 'Mold Removal', desc: 'IICRC-certified inspection, containment, and remediation.', href: '/services/mold-removal' },
  { num: '03', title: 'Fire & Smoke', desc: 'Full restoration and direct insurance coordination.', href: '/services/fire-damage' },
  { num: '04', title: 'Hurricane Response', desc: 'Roof tarping, water extraction, mold prevention.', href: '/services/hurricane-emergency' },
  { num: '05', title: 'Impact Windows', desc: 'Hurricane-rated installation, insurance discounts.', href: '/services/impact-windows' },
];

const credentials = [
  'IICRC Certified',
  'Insurance Direct Billing',
  'Licensed & Insured',
  'Bilingual Team',
  '36 Years in South Florida',
];
---

<BaseLayout title={title} description={description} lang="en" pathname="/">

  <!-- ===================================================
       HERO — Premium Liquid Glass · 100vh · centered
       =================================================== -->
  <section
    class="relative overflow-hidden text-white"
    style="min-height: 100vh; display: flex; flex-direction: column; background: #050A14;"
  >
    <!-- ── Video background ── -->
    <video
      class="absolute inset-0 w-full h-full object-cover pointer-events-none"
      autoplay muted loop playsinline preload="auto"
      width="1920" height="1080"
      aria-hidden="true"
      poster="https://res.cloudinary.com/dxdibfgvw/image/upload/w_1920,h_1080,c_fill,q_auto:best,f_auto/v1779848047/GettyImages-1399919975_1_j9bdot.jpg"
    >
      <source
        media="(max-width: 768px)"
        src="https://res.cloudinary.com/dxdibfgvw/video/upload/w_720,h_1280,c_fill,q_auto:eco,f_mp4,br_600k,du_15/v1779848047/GettyImages-1399919975_1_j9bdot.mov"
        type="video/mp4"
      />
      <source
        src="https://res.cloudinary.com/dxdibfgvw/video/upload/w_1920,h_1080,c_fill,q_auto:best,f_mp4,br_5000k,du_15/v1779848047/GettyImages-1399919975_1_j9bdot.mov"
        type="video/mp4"
      />
    </video>

    <!-- ── Cinematic overlay ── -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
      style="background: radial-gradient(ellipse 120% 100% at 50% 0%, rgba(5,10,20,0.30) 0%, rgba(5,10,20,0.72) 100%);"></div>
    <div class="absolute inset-x-0 bottom-0 h-48 pointer-events-none" aria-hidden="true"
      style="background: linear-gradient(to top, rgba(5,10,20,0.92) 0%, transparent 100%);"></div>

    <!-- ── Center content ── -->
    <div class="relative flex-1 flex flex-col items-center justify-center text-center px-5 pt-32 pb-36 lg:pt-36 lg:pb-40">

      <!-- Eyebrow badge -->
      <p class="gsap-hero-elem inline-flex items-center gap-2 text-xs uppercase font-semibold mb-8 px-5 py-2.5 rounded-full"
        style="color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); letter-spacing: 0.1em; backdrop-filter: blur(8px); opacity: 0;">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse shrink-0" style="background: #DC2626;" aria-hidden="true"></span>
        24/7 Emergency Response
      </p>

      <!-- H1 -->
      <h1 class="gsap-hero-elem font-extrabold mb-6 max-w-4xl"
        style="font-size: var(--text-display); font-family: var(--font-display); letter-spacing: -0.025em; line-height: 1.06; opacity: 0;">
        When disaster strikes,<br />
        <span style="color: var(--color-green);">we're already on the way.</span>
      </h1>

      <!-- Sub-copy -->
      <p class="gsap-hero-elem text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-8"
        style="color: rgba(255,255,255,0.90); opacity: 0;">
        South Florida's 24/7 disaster response experts. We handle rapid cleanup, certified restoration, and direct insurance claims—so you can focus on getting back to normal.
      </p>

      <!-- CTAs -->
      <div class="gsap-hero-elem flex flex-col sm:flex-row items-center gap-3" style="opacity: 0;">
        <a href={`tel:${emergencyPhone.e164}`}
          class="btn-emergency gsap-pulse text-base py-3 px-6 whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call {emergencyPhone.display}
        </a>
        <a href="/contact" class="btn-trust text-base py-3 px-6 whitespace-nowrap">
          Book Free Inspection
        </a>
      </div>

    </div>

    <!-- ── Bottom trust bar ── -->
    <div class="absolute bottom-0 left-0 right-0 px-4 pb-5 lg:pb-6 gsap-hero-elem" style="opacity: 0;">
      <div class="max-w-3xl mx-auto rounded-2xl lg:rounded-full flex flex-wrap items-center justify-center gap-x-5 gap-y-2 px-5 py-3"
        style="background: rgba(10,15,30,0.55); backdrop-filter: blur(20px) saturate(1.5); -webkit-backdrop-filter: blur(20px) saturate(1.5); border: 1px solid rgba(255,255,255,0.10); box-shadow: 0 8px 32px rgba(0,0,0,0.30), inset 0 1px 0 rgba(255,255,255,0.06);">
        {credentials.map((c) => (
          <span class="flex items-center gap-1.5 text-xs font-medium" style="color: rgba(255,255,255,0.55);">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7l3.5 3.5 6.5-6.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {c}
          </span>
        ))}
      </div>
    </div>

  </section>

  <!-- Services Bento -->
  <ServicesSection lang="en" />

  <!-- Testimonials Carousel -->
  <Testimonials lang="en" />

  <!-- ===================================================
       INSURANCE STRIP
       =================================================== -->
  <section class="section-y" style="background: var(--color-surface-alt);">
    <div class="container-x max-w-3xl text-center">
      <h2 class="text-3xl lg:text-4xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">We work directly with your insurance.</h2>
      <p class="text-lg leading-relaxed mb-6" style="color: var(--color-ink-soft);">
        No out-of-pocket cost for covered claims. We coordinate documentation,
        scoping, and direct billing with your adjuster so you can focus on your
        family, not paperwork.
      </p>
      <p class="text-sm font-medium" style="color: var(--color-ink-soft);">
        {business.insurancePartners.join(' · ')}
      </p>
    </div>
  </section>

  <!-- ===================================================
       FINAL CTA
       =================================================== -->
  <section class="section-y text-center" style="background: var(--color-ink); color: white;">
    <div class="container-x">
      <h2 class="text-3xl lg:text-5xl font-bold mb-4" style="font-family: var(--font-display); letter-spacing: -0.02em;">
        Water doesn't wait.<br class="hidden sm:block" /> Neither do we.
      </h2>
      <p class="text-lg mb-8" style="color: rgba(255,255,255,0.7);">
        Emergency response across all of South Florida. Call now.
      </p>
      <a href={`tel:${emergencyPhone.e164}`} class="btn-emergency text-xl">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {emergencyPhone.display}
      </a>
    </div>
  </section>

  <!-- ===================================================
       GSAP — ANIMACIONES CORREGIDAS Y SEGURA
       =================================================== -->
  <script>
    // Verificamos que estamos en el navegador
    if (typeof window !== 'undefined') {
      // Importamos GSAP de forma segura
      import('gsap').then((gsapModule) => {
        const gsap = gsapModule.gsap;
        
        // Verificamos si el usuario prefiere movimiento reducido
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        if (prefersReduced) {
          // Si prefiere no animar, simplemente mostramos todo
          document.querySelectorAll('.gsap-hero-elem').forEach((el) => {
            el.style.opacity = '1';
            el.style.transform = 'none';
          });
        } else {
          // Animación normal
          const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

          // Badge
          tl.to('.gsap-hero-elem:nth-child(1)', { opacity: 1, y: 0, duration: 0.8 }, 0);
          
          // Título
          tl.to('.gsap-hero-elem:nth-child(2)', { opacity: 1, y: 0, duration: 1, ease: 'expo.out' }, '-=0.5');
          
          // Subtítulo
          tl.to('.gsap-hero-elem:nth-child(3)', { opacity: 1, y: 0, duration: 0.8 }, '-=0.6');
          
          // Botones
          tl.to('.gsap-hero-elem:nth-child(4)', { opacity: 1, y: 0, duration: 0.6, stagger: 0.1 }, '-=0.4');
          
          // Barra inferior
          tl.to('.gsap-hero-elem:nth-child(5)', { opacity: 1, y: 0, duration: 0.6 }, '-=0.3');

          // Configuración inicial de los elementos (posición y opacidad)
          // Esto se ejecuta antes de la animación para evitar "flash" de contenido
          gsap.set('.gsap-hero-elem', { opacity: 0, y: 30 });
          
          // Reiniciamos la timeline para que tome el estado set
          tl.play(0);
          
          // Pulso en botón de emergencia
          gsap.to('.gsap-pulse', {
            scale: 1.03,
            duration: 1.5,
            repeat: -1,
            yoyo: true,
            ease: 'power1.inOut',
          });
        }
      }).catch(err => {
        console.error('GSAP failed to load:', err);
        // Fallback: Si falla la carga, mostramos todo
        document.querySelectorAll('.gsap-hero-elem').forEach((el) => {
          el.style.opacity = '1';
          el.style.transform = 'none';
        });
      });
    }
  </script>

</BaseLayout>