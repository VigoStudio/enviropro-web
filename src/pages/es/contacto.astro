---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business, emergencyPhone, miamiPhone, browardPhone, orlandoPhone } from '../../data/business';

const title = 'Contacto EnviroPro USA · Restauración de Emergencia 24/7 · Miami';
const description = 'Llame 24/7 para restauración de daños por agua, moho, fuego y huracanes en Miami-Dade, Broward y Orlando. Equipo bilingüe, facturación directa con aseguradora.';

const contactEmail = business.email.support;

const offices = [
  { region: 'Miami-Dade', phone: miamiPhone, area: 'Pinecrest · Coral Gables · Kendall · Doral · Hialeah · Brickell' },
  { region: 'Broward', phone: browardPhone, area: 'Fort Lauderdale · Hollywood · Pembroke Pines · Aventura' },
  { region: 'Orlando', phone: orlandoPhone, area: 'Winter Park · Lake Nona · Dr. Phillips · Windermere' },
];
---

<BaseLayout title={title} description={description} lang="es" pathname="/es/contacto">

  <section style="background: var(--color-emergency)" class="text-white py-4">
    <div class="container-x flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-semibold text-lg">⚠️ ¿Emergencia? No llene el formulario — llame ahora.</p>
      <a href={`tel:${emergencyPhone.e164}`} class="bg-white text-[var(--color-emergency)] font-bold px-6 py-3 rounded-lg hover:bg-gray-100 transition-colors">
        {emergencyPhone.display} · 24/7
      </a>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-white">
    <div class="container-x max-w-4xl text-center">
      <h1 class="text-4xl lg:text-6xl font-bold mb-6" style="font-family: var(--font-display)">
        Tres formas de contactarnos.
      </h1>
      <p class="text-xl" style="color: var(--color-ink-soft)">
        Llame para emergencias. WhatsApp para preguntas rápidas. Formulario para servicio programado o cotizaciones.
      </p>
    </div>
  </section>

  <section class="pb-16 bg-white">
    <div class="container-x">
      <h2 class="text-2xl font-bold mb-8 text-center" style="font-family: var(--font-display)">Oficina por región</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {offices.map((office) => (
          <div class="p-7 rounded-2xl border-2 border-[var(--color-border)] hover:border-[var(--color-trust)] transition-colors">
            <p class="text-xs uppercase tracking-widest font-bold mb-2" style="color: var(--color-trust)">
              {office.region}
            </p>
            <a href={`tel:${office.phone.e164}`} class="block text-2xl font-bold mb-3 hover:underline">
              {office.phone.display}
            </a>
            <p class="text-sm" style="color: var(--color-ink-soft)">{office.area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-y" style="background: var(--color-surface-alt)">
    <div class="container-x grid grid-cols-1 lg:grid-cols-2 gap-10">

      <div class="bg-white p-8 rounded-2xl shadow-sm">
        <h2 class="text-2xl lg:text-3xl font-bold mb-2" style="font-family: var(--font-display)">
          Agendar servicio o cotización
        </h2>
        <p class="mb-6" style="color: var(--color-ink-soft)">
          Respondemos solicitudes no urgentes en menos de 4 horas hábiles.
        </p>

        <form
          action={`mailto:${contactEmail}`}
          method="post"
          enctype="text/plain"
          class="space-y-4"
        >
          <div>
            <label for="name" class="block text-sm font-semibold mb-1">Nombre *</label>
            <input
              type="text"
              id="name"
              name="Nombre"
              required
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)]"
            />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="phone" class="block text-sm font-semibold mb-1">Teléfono *</label>
              <input
                type="tel"
                id="phone"
                name="Telefono"
                required
                class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)]"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold mb-1">Email *</label>
              <input
                type="email"
                id="email"
                name="Email"
                required
                class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)]"
              />
            </div>
          </div>

          <div>
            <label for="service" class="block text-sm font-semibold mb-1">Servicio necesario *</label>
            <select
              id="service"
              name="Servicio"
              required
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)] bg-white"
            >
              <option value="">Seleccione un servicio…</option>
              <option>Daños por Agua</option>
              <option>Remoción de Moho</option>
              <option>Daños por Fuego y Humo</option>
              <option>Emergencia de Huracán</option>
              <option>Ventanas de Impacto</option>
              <option>Otro / No estoy seguro</option>
            </select>
          </div>

          <div>
            <label for="urgency" class="block text-sm font-semibold mb-1">Urgencia</label>
            <select
              id="urgency"
              name="Urgencia"
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)] bg-white"
            >
              <option>Programado / no urgente</option>
              <option>En las próximas 24-48 horas</option>
              <option>Hoy (mejor llámenos)</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold mb-1">Cuéntenos qué pasó</label>
            <textarea
              id="message"
              name="Mensaje"
              rows="4"
              class="w-full px-4 py-3 border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-trust)] resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-trust w-full text-lg py-4">
            Enviar Mensaje
          </button>

          <p class="text-xs text-center" style="color: var(--color-ink-soft)">
            * Campos requeridos. Respondemos en menos de 4 horas hábiles.
          </p>
        </form>
      </div>

      <div class="space-y-6">
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold mb-2" style="font-family: var(--font-display)">
            Visite nuestra oficina
          </h2>
          <p style="color: var(--color-ink-soft)">Solo con cita previa — la respuesta de emergencia se despacha, no atendemos walk-ins.</p>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm">
          <p class="text-xs uppercase tracking-widest font-bold mb-2" style="color: var(--color-trust)">Oficina Central</p>
          <address class="text-lg not-italic font-semibold mb-4">
            {business.address.street}<br/>
            {business.address.city}, {business.address.state} {business.address.zip}
          </address>

          <div class="space-y-2 text-sm">
            <p><span class="font-semibold">Emergencias:</span> 24/7 — 365 días</p>
            <p><span class="font-semibold">Horario oficina:</span> Lun-Vie 8AM-6PM EST</p>
          </div>

          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(business.address.formatted)}`}
            target="_blank"
            rel="noopener"
            class="inline-block mt-4 font-semibold text-sm hover:underline"
            style="color: var(--color-trust)"
          >
            Abrir en Google Maps →
          </a>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-sm bg-white">
          <iframe
            src={`https://www.google.com/maps?q=${business.geo.latitude},${business.geo.longitude}&z=15&output=embed`}
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="EnviroPro USA ubicación"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
