---
/**
 * Testimonials.astro — Carousel infinito con auto-scroll
 * Fondo: var(--color-trust) · Tarjetas blancas · Bilingüe
 */

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

// SVG de estrella reutilizable
const starPath = 'M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z';

const t = {
  en: {
    heading: 'What Our Customers Say',
    sub: 'Trusted by thousands of South Florida homeowners',
    reviews: [
      {
        name: 'Melissa Clark',
        role: 'Homeowner · Pinecrest, FL',
        initials: 'MC',
        color: '#4384BF',
        rating: 5,
        text: '"EnviroPro responded within an hour after our pipe burst. Professional, bilingual, and worked directly with our insurance. Absolutely the best in South Florida."',
        source: 'Google',
      },
      {
        name: 'James Ortega',
        role: 'Property Manager · Miami, FL',
        initials: 'JO',
        color: '#00A38A',
        rating: 5,
        text: '"After the hurricane hit, they had crews on-site the next morning. Water extracted, mold prevented, roof tarped — done right the first time. Five stars without hesitation."',
        source: 'Google',
      },
      {
        name: 'Sandra Ruiz',
        role: 'Homeowner · Doral, FL',
        initials: 'SR',
        color: '#D97706',
        rating: 5,
        text: '"The mold remediation was thorough and they explained every step clearly. The team was respectful of our home and finished ahead of schedule. Highly recommend!"',
        source: 'Yelp',
      },
      {
        name: 'Robert Kim',
        role: 'Business Owner · Fort Lauderdale, FL',
        initials: 'RK',
        color: '#7C3AED',
        rating: 5,
        text: '"Fire damage in my shop and they handled everything — cleaning, odor removal, even the insurance paperwork. I was back open in two weeks. Exceptional service."',
        source: 'Google',
      },
      {
        name: 'Laura Mendez',
        role: 'Homeowner · Coral Gables, FL',
        initials: 'LM',
        color: '#DC2626',
        rating: 5,
        text: '"I called at 2 AM after a major water leak and they picked up immediately. A tech arrived in under an hour. Calm, professional, and incredibly efficient. Thank you!"',
        source: 'Google',
      },
      {
        name: 'Carlos Vega',
        role: 'HOA Director · Hollywood, FL',
        initials: 'CV',
        color: '#059669',
        rating: 5,
        text: '"We\'ve used EnviroPro for three buildings now. Consistent quality, transparent pricing, and they work seamlessly with our insurance carriers. Our go-to restoration company."',
        source: 'HomeAdvisor',
      },
    ],
  },
  es: {
    heading: 'Lo Que Dicen Nuestros Clientes',
    sub: 'La confianza de miles de familias en South Florida',
    reviews: [
      {
        name: 'Melissa Clark',
        role: 'Propietaria · Pinecrest, FL',
        initials: 'MC',
        color: '#4384BF',
        rating: 5,
        text: '"EnviroPro llegó en menos de una hora después de que reventó una tubería. Profesionales, bilingües y trabajaron directamente con nuestro seguro. Los mejores del sur de Florida."',
        source: 'Google',
      },
      {
        name: 'James Ortega',
        role: 'Administrador de Propiedades · Miami, FL',
        initials: 'JO',
        color: '#00A38A',
        rating: 5,
        text: '"Después del huracán, llegaron a la mañana siguiente. Extrajeron el agua, previnieron el moho y cubrieron el techo — todo bien hecho desde el principio. Cinco estrellas."',
        source: 'Google',
      },
      {
        name: 'Sandra Ruiz',
        role: 'Propietaria · Doral, FL',
        initials: 'SR',
        color: '#D97706',
        rating: 5,
        text: '"La remediación de moho fue exhaustiva y explicaron cada paso claramente. El equipo fue muy respetuoso con nuestra casa y terminaron antes de lo previsto. ¡Los recomiendo!"',
        source: 'Yelp',
      },
      {
        name: 'Robert Kim',
        role: 'Empresario · Fort Lauderdale, FL',
        initials: 'RK',
        color: '#7C3AED',
        rating: 5,
        text: '"Daños por fuego en mi local y se encargaron de todo: limpieza, eliminación de olores, y hasta los trámites del seguro. Volví a abrir en dos semanas. Servicio excepcional."',
        source: 'Google',
      },
      {
        name: 'Laura Méndez',
        role: 'Propietaria · Coral Gables, FL',
        initials: 'LM',
        color: '#DC2626',
        rating: 5,
        text: '"Llamé a las 2 AM por una fuga enorme y respondieron de inmediato. Un técnico llegó en menos de una hora. Tranquilos, profesionales e increíblemente eficientes. ¡Gracias!"',
        source: 'Google',
      },
      {
        name: 'Carlos Vega',
        role: 'Director HOA · Hollywood, FL',
        initials: 'CV',
        color: '#059669',
        rating: 5,
        text: '"Hemos usado EnviroPro en tres edificios. Calidad constante, precios transparentes y trabajan muy bien con nuestras aseguradoras. Nuestra empresa de restauración de confianza."',
        source: 'HomeAdvisor',
      },
    ],
  },
}[lang];

// Duplicamos las tarjetas para el loop infinito
const allCards = [...t.reviews, ...t.reviews];
---

<section class="testimonials-section overflow-hidden py-16 lg:py-24" style="background: var(--color-trust);">
  <div class="max-w-6xl mx-auto px-5 lg:px-8 mb-12">

    <!-- Header -->
    <div class="text-center">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3"
        style="color: rgba(255,255,255,0.55); letter-spacing: 0.12em;">
        {t.sub}
      </p>
      <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight">
        {t.heading}
      </h2>
    </div>

  </div>

  <!-- ── Carousel track ── -->
  <!--
    Truco del loop infinito:
    - El track tiene 2× las tarjetas (originals + duplicados).
    - La animación va de translateX(0) → translateX(-50%).
    - Cuando llega al -50%, vuelve a 0 sin salto visible.
  -->
  <div class="carousel-wrapper">
    <div class="carousel-track">
      {allCards.map((review, i) => (
        <article class="carousel-card" aria-label={`Review by ${review.name}`}>

          <!-- Avatar + nombre -->
          <div class="flex items-center gap-4 mb-5">
            <div
              class="avatar-circle"
              style={`background: ${review.color};`}
              aria-hidden="true"
            >
              {review.initials}
            </div>
            <div>
              <p class="font-bold text-slate-900 text-base leading-tight">{review.name}</p>
              <p class="text-slate-500 text-sm mt-0.5">{review.role}</p>
            </div>
          </div>

          <!-- Estrellas -->
          <div class="flex gap-0.5 mb-4" aria-label={`${review.rating} out of 5 stars`}>
            {Array.from({ length: review.rating }).map(() => (
              <svg class="star-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
            ))}
          </div>

          <!-- Texto -->
          <p class="review-text">{review.text}</p>

          <!-- Footer: fuente -->
          <div class="mt-6 pt-5 border-t border-slate-100 flex items-center justify-between">
            <span class="source-badge">{review.source}</span>
            <div class="flex gap-0.5">
              {Array.from({ length: 3 }).map(() => (
                <span class="w-1 h-1 rounded-full bg-slate-200 inline-block"></span>
              ))}
            </div>
          </div>

        </article>
      ))}
    </div>
  </div>

  <!-- Indicadores de posición (decorativos) -->
  <div class="flex justify-center gap-2 mt-10" aria-hidden="true">
    {t.reviews.map((_, i) => (
      <span class={`dot ${i === 0 ? 'dot-active' : ''}`}></span>
    ))}
  </div>

</section>

<style>
  /* ── Wrapper: oculta el overflow del track ── */
  .carousel-wrapper {
    overflow: hidden;
    /* Fades en los bordes para efecto de profundidad */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  /* ── Track: flex horizontal con animación ── */
  .carousel-track {
    display: flex;
    gap: 0;
    width: max-content;
    animation: marquee 40s linear infinite;
  }

  /* Pausar al hacer hover sobre la sección */
  .testimonials-section:hover .carousel-track {
    animation-play-state: paused;
  }

  /* ── Keyframes: 0 → -50% para el loop perfecto ── */
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── Tarjeta individual ── */
  .carousel-card {
    flex-shrink: 0;
    width: 400px;
    background: #ffffff;
    border-radius: 24px;
    padding: 32px;
    margin: 0 12px;
    box-shadow:
      0 4px 6px rgba(0,0,0,0.04),
      0 12px 28px rgba(0,0,0,0.10);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .carousel-card:hover {
    transform: translateY(-4px);
    box-shadow:
      0 8px 12px rgba(0,0,0,0.06),
      0 20px 40px rgba(0,0,0,0.14);
  }

  /* ── Avatar con iniciales ── */
  .avatar-circle {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.875rem;
    font-weight: 700;
    color: white;
    letter-spacing: 0.03em;
  }

  /* ── Estrellas ── */
  .star-icon {
    width: 18px;
    height: 18px;
    color: #F59E0B;
  }

  /* ── Texto del review ── */
  .review-text {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #374151;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Badge de fuente ── */
  .source-badge {
    font-size: 0.75rem;
    font-weight: 600;
    color: #6B7280;
    background: #F3F4F6;
    padding: 3px 10px;
    border-radius: 100px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── Indicadores ── */
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    transition: background 0.3s ease, width 0.3s ease;
  }

  .dot-active {
    width: 24px;
    border-radius: 4px;
    background: rgba(255,255,255,0.90);
  }

  /* ── Mobile: tarjetas más angostas ── */
  @media (max-width: 640px) {
    .carousel-card {
      width: 300px;
      padding: 24px;
      margin: 0 8px;
    }

    .review-text {
      font-size: 0.875rem;
      -webkit-line-clamp: 3;
    }
  }

  /* ── Reduced motion: quita la animación ── */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none !important;
    }
  }
</style>
