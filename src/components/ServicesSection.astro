---
/**
 * ServicesSection.astro — Bento-style restoration services grid.
 * Featured card (Water Damage) spans left column full height.
 * Cards 02–05: hover reveals Cloudinary background image (desktop only).
 */
import { emergencyPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

// Images are service-specific, language-agnostic
const serviceImages = [
  'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto,dpr_auto/v1779853414/mold1_iuqg9y.jpg',
  'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto,dpr_auto/v1779853304/fireandsmoke_orcmkk.jpg',
  'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto,dpr_auto/v1779853304/hurricane_jozczp.jpg',
  'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto,dpr_auto/v1779853304/safetywindow_rfsksm.jpg',
];

const t = {
  en: {
    sectionTitle: 'Restoration Services',
    viewAll: 'View all services →',
    viewAllHref: '/services',
    featured: {
      num: '01',
      title: 'Water Damage Restoration',
      desc: 'Pipe bursts, flooding, storm water — the clock starts the moment water enters your property. We aim to be on-site in under 60 minutes.',
      steps: ['Emergency dispatch', 'Water extraction', 'Structural drying', 'Full restoration'],
      cta: `Call ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Mold Removal',      desc: 'IICRC-certified inspection, containment, and full remediation.',                href: '/services/mold-removal',        imgAlt: 'Mold remediation in progress' },
      { num: '03', title: 'Fire & Smoke',       desc: 'Structure cleaning, odor removal, and direct insurance coordination.',          href: '/services/fire-damage',         imgAlt: 'Fire and smoke damage restoration' },
      { num: '04', title: 'Hurricane Response', desc: 'Roof tarping, water extraction, and rapid mold prevention.',                   href: '/services/hurricane-emergency', imgAlt: 'Hurricane damage response' },
      { num: '05', title: 'Impact Windows',     desc: 'Hurricane-rated installation eligible for insurance premium discounts.',        href: '/services/impact-windows',      imgAlt: 'Impact-resistant window installation' },
    ],
    learnMore: 'Learn more →',
  },
  es: {
    sectionTitle: 'Servicios de Restauración',
    viewAll: 'Ver todos los servicios →',
    viewAllHref: '/es/servicios',
    featured: {
      num: '01',
      title: 'Restauración por Daños de Agua',
      desc: 'Tuberías rotas, inundaciones, agua de tormenta — el reloj comienza cuando el agua entra a tu propiedad. Llegamos en menos de 60 minutos.',
      steps: ['Despacho de emergencia', 'Extracción de agua', 'Secado estructural', 'Restauración completa'],
      cta: `Llamar ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Eliminación de Moho',  desc: 'Inspección, contención y remediación certificada por IICRC.',                   href: '/es/servicios/moho',               imgAlt: 'Remediación de moho en progreso' },
      { num: '03', title: 'Incendio y Humo',       desc: 'Limpieza estructural, eliminación de olores y coordinación con seguros.',       href: '/es/servicios/incendio',           imgAlt: 'Restauración por daños de incendio' },
      { num: '04', title: 'Respuesta a Huracanes', desc: 'Cubierta de techos, extracción de agua y prevención rápida de moho.',          href: '/es/servicios/huracanes',          imgAlt: 'Respuesta a daños por huracán' },
      { num: '05', title: 'Ventanas de Impacto',   desc: 'Instalación resistente a huracanes con descuentos en primas de seguro.',       href: '/es/servicios/ventanas-impacto',   imgAlt: 'Instalación de ventanas de impacto' },
    ],
    learnMore: 'Ver más →',
  },
};

const copy = t[lang];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">

    <!-- Section header -->
    <div class="flex items-end justify-between mb-8 lg:mb-10">
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 leading-tight">
        {copy.sectionTitle}
      </h2>
      <a
        href={copy.viewAllHref}
        class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold shrink-0 ml-4 transition-colors hover:underline"
        style="color: #4384BF;"
      >
        {copy.viewAll}
      </a>
    </div>

    <!-- Bento grid -->
    <div class="bento-grid">

      <!-- ── Card 01: Featured (blue, row-span-2) ── -->
      <article
        role="article"
        aria-label={copy.featured.title}
        class="card-featured group flex flex-col h-full rounded-2xl p-8 cursor-pointer
               transition-all duration-300 ease-in-out
               hover:-translate-y-2 hover:shadow-xl"
        style="background: #4384BF;"
      >
        <!-- Number -->
        <span class="text-xs font-bold tracking-widest text-white/50 mb-5 block">
          {copy.featured.num}
        </span>

        <!-- Title -->
        <h3 class="text-2xl lg:text-3xl font-bold text-white leading-snug mb-4">
          {copy.featured.title}
        </h3>

        <!-- Description -->
        <p class="text-white/80 text-sm lg:text-base leading-relaxed mb-6">
          {copy.featured.desc}
        </p>

        <!-- Steps — flex-1 pushes CTA to bottom -->
        <ul class="flex flex-col gap-3 flex-1">
          {copy.featured.steps.map((step, i) => (
            <li class="flex items-center gap-3">
              <span
                class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold"
                style="background: rgba(255,255,255,0.22); color: #4384BF;"
              >
                {i + 1}
              </span>
              <span class="text-sm text-white/90">{step}</span>
            </li>
          ))}
        </ul>

        <!-- CTA — red call button, pinned to bottom -->
        <div class="mt-auto pt-8">
          <a
            href={copy.featured.ctaHref}
            class="flex items-center justify-center gap-2 w-full
                   bg-red-600 hover:bg-red-700 text-white font-bold
                   py-3 px-6 rounded-lg text-sm transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {copy.featured.cta}
          </a>
        </div>
      </article>

      <!-- ── Cards 02–05: Secondary services with hover image ── -->
      {copy.secondary.map((svc, i) => (
        <a
          href={svc.href}
          role="article"
          aria-label={svc.title}
          class="card-secondary group relative overflow-hidden rounded-2xl p-6 lg:p-7
                 flex flex-col justify-between
                 cursor-pointer transition-all duration-300 ease-in-out
                 hover:-translate-y-2 hover:shadow-xl"
          style="background: #F8FAFC; min-height: 200px;"
        >

          <!-- ── Background image (desktop hover only) ── -->
          <div class="card-bg-img absolute inset-0 z-0" aria-hidden="true">
            <img
              src={serviceImages[i]}
              alt=""
              aria-hidden="true"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover
                     blur-[2px]
                     opacity-0 md:group-hover:opacity-100
                     scale-100 md:group-hover:scale-105
                     transition-all duration-500 ease-in-out"
            />
          </div>

          <!-- ── Gradient overlay (text protection, always visible on hover) ── -->
          <div
            class="card-overlay absolute inset-0 z-10
                   opacity-0 md:group-hover:opacity-100
                   transition-opacity duration-500 ease-in-out"
            style="background: linear-gradient(to right, rgba(255,255,255,0.97) 0%, rgba(255,255,255,0.88) 55%, rgba(255,255,255,0.3) 100%);"
            aria-hidden="true"
          />

          <!-- ── Content — always above image and overlay ── -->
          <div class="relative z-20 flex flex-col flex-1">

            <!-- Number accent -->
            <span class="text-xs font-bold tracking-widest mb-4 block" style="color: #D97706;">
              {svc.num}
            </span>

            <!-- Title — shifts to blue on hover -->
            <h3 class="text-base lg:text-lg font-bold text-slate-900 leading-snug mb-2
                       group-hover:text-blue-600 transition-colors duration-300">
              {svc.title}
            </h3>

            <!-- Description -->
            <p class="text-sm text-slate-500 leading-relaxed flex-1">
              {svc.desc}
            </p>

            <!-- Learn more — always at bottom -->
            <span
              class="inline-flex items-center gap-1 text-sm font-semibold mt-5 transition-colors duration-300 group-hover:text-blue-700"
              style="color: #4384BF;"
            >
              {copy.learnMore}
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile: view all -->
    <div class="mt-8 text-center sm:hidden">
      <a href={copy.viewAllHref} class="text-sm font-semibold" style="color: #4384BF;">
        {copy.viewAll}
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Bento grid layout ── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  /* Tablet: featured full-width, 2-col secondaries */
  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .card-featured {
      grid-column: 1 / -1;
    }
  }

  /* Desktop: 3-col bento — featured left spans both rows */
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: 1.1fr 1fr 1fr;
      grid-template-rows: repeat(2, auto);
      gap: 1.25rem;
    }
    .card-featured {
      grid-column: 1;
      grid-row: 1 / span 2;
    }
  }

  /* ── Mobile: clean white card with brand left-border accent ── */
  .card-secondary {
    border: 1px solid #E2E8F0;
    border-left: 4px solid #4384BF;
  }

  /* Desktop: uniform thin border (image hover replaces accent) */
  @media (min-width: 768px) {
    .card-secondary {
      border: 1px solid #E2E8F0;
    }
  }

  /* ── Respect prefers-reduced-motion ── */
  @media (prefers-reduced-motion: reduce) {
    .card-secondary img,
    .card-overlay,
    .card-secondary {
      transition: none !important;
    }
    /* Still show the image on hover, just without animation */
    .card-secondary:hover img {
      opacity: 0.6;
      transform: none;
    }
    .card-secondary:hover .card-overlay {
      opacity: 1;
    }
  }
</style>
