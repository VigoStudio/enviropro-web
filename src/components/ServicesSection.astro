---
/**
 * ServicesSection.astro — Grid híbrido:
 *   Col 1 (lg): Tarjeta azul con steps + CTA (Water Damage)
 *   Cols 2–3 (lg): Premium Cutout cards (02–05)
 */
import { emergencyPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const imgs = {
  mold:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_600,h_400,c_fill,f_auto,q_auto/v1779853414/mold1_iuqg9y.jpg',
  fire:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_600,h_400,c_fill,f_auto,q_auto/v1779853304/fireandsmoke_orcmkk.jpg',
  hurricane: 'https://res.cloudinary.com/dxdibfgvw/image/upload/w_600,h_400,c_fill,f_auto,q_auto/v1779853304/hurricane_jozczp.jpg',
  windows:   'https://res.cloudinary.com/dxdibfgvw/image/upload/w_600,h_400,c_fill,f_auto,q_auto/v1779853304/safetywindow_rfsksm.jpg',
};

const t = {
  en: {
    sectionTitle: 'Restoration Services',
    viewAll: 'View all services',
    viewAllHref: '/services',
    viewMore: 'View more',
    featured: {
      num: '01',
      title: 'Water Damage Restoration',
      desc: 'Pipe bursts, flooding, storm water — the clock starts the moment water enters your property. We aim to be on-site in under 60 minutes.',
      steps: ['Emergency dispatch', 'Water extraction', 'Structural drying', 'Full restoration'],
      cta: `Call ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Mold Removal',      desc: 'IICRC-certified inspection, containment, and full remediation.',                href: '/services/mold-removal',        img: imgs.mold,      imgAlt: 'Mold remediation in progress' },
      { num: '03', title: 'Fire & Smoke',       desc: 'Structure cleaning, odor removal, and direct insurance coordination.',          href: '/services/fire-damage',         img: imgs.fire,      imgAlt: 'Fire and smoke damage restoration' },
      { num: '04', title: 'Hurricane Response', desc: 'Roof tarping, water extraction, and rapid mold prevention.',                   href: '/services/hurricane-emergency', img: imgs.hurricane, imgAlt: 'Hurricane damage response' },
      { num: '05', title: 'Impact Windows',     desc: 'Hurricane-rated installation eligible for insurance premium discounts.',        href: '/services/impact-windows',      img: imgs.windows,   imgAlt: 'Impact-resistant window installation' },
    ],
  },
  es: {
    sectionTitle: 'Servicios de Restauración',
    viewAll: 'Ver todos los servicios',
    viewAllHref: '/es/servicios',
    viewMore: 'Ver más',
    featured: {
      num: '01',
      title: 'Restauración por Daños de Agua',
      desc: 'Tuberías rotas, inundaciones, agua de tormenta — el reloj comienza cuando el agua entra a tu propiedad. Llegamos en menos de 60 minutos.',
      steps: ['Despacho de emergencia', 'Extracción de agua', 'Secado estructural', 'Restauración completa'],
      cta: `Llamar ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Eliminación de Moho',  desc: 'Inspección, contención y remediación certificada por IICRC.',              href: '/es/servicios/moho',             img: imgs.mold,      imgAlt: 'Remediación de moho en progreso' },
      { num: '03', title: 'Incendio y Humo',       desc: 'Limpieza estructural, eliminación de olores y coordinación con seguros.',  href: '/es/servicios/incendio',         img: imgs.fire,      imgAlt: 'Restauración por daños de incendio' },
      { num: '04', title: 'Respuesta a Huracanes', desc: 'Cubierta de techos, extracción de agua y prevención rápida de moho.',     href: '/es/servicios/huracanes',        img: imgs.hurricane, imgAlt: 'Respuesta a daños por huracán' },
      { num: '05', title: 'Ventanas de Impacto',   desc: 'Instalación resistente a huracanes con descuentos en primas de seguro.',  href: '/es/servicios/ventanas-impacto', img: imgs.windows,   imgAlt: 'Instalación de ventanas de impacto' },
    ],
  },
}[lang];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">

    <!-- Section header -->
    <div class="flex items-center justify-between mb-10 lg:mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 leading-tight">
        {t.sectionTitle}
      </h2>
      <a
        href={t.viewAllHref}
        class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold shrink-0 ml-4 transition-opacity hover:opacity-70"
        style="color: var(--color-trust);"
      >
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- ── Hybrid grid ── -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">

      <!-- ══════════════════════════════════════════════
           Card 01 — Azul featured (col 1, full height)
           ══════════════════════════════════════════════ -->
      <article
        aria-label={t.featured.title}
        class="group flex flex-col h-full rounded-3xl p-8 cursor-pointer
               transition-all duration-300 ease-in-out
               hover:-translate-y-1 hover:shadow-2xl"
        style="background: var(--color-trust); min-height: 500px;"
      >
        <span class="text-xs font-bold tracking-widest text-white/50 mb-5 block">
          {t.featured.num}
        </span>

        <h3 class="text-2xl lg:text-3xl font-bold text-white leading-snug mb-4"
          style="font-family: var(--font-display);">
          {t.featured.title}
        </h3>

        <p class="text-white/80 text-sm lg:text-base leading-relaxed mb-6">
          {t.featured.desc}
        </p>

        <ul class="flex flex-col gap-3 flex-1">
          {t.featured.steps.map((step, i) => (
            <li class="flex items-center gap-3">
              <span
                class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold"
                style="background: rgba(255,255,255,0.22); color: var(--color-trust);"
              >
                {i + 1}
              </span>
              <span class="text-sm text-white/90">{step}</span>
            </li>
          ))}
        </ul>

        <div class="mt-auto pt-8">
          <a
            href={t.featured.ctaHref}
            class="flex items-center justify-center gap-2 w-full
                   text-white font-bold py-3 px-6 rounded-xl text-sm transition-all
                   hover:opacity-90 hover:shadow-lg"
            style="background: var(--color-green);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {t.featured.cta}
          </a>
        </div>
      </article>

      <!-- ══════════════════════════════════════════════
           Cards 02–05 — Premium Cutout
           ══════════════════════════════════════════════ -->
      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-6">
        {t.secondary.map((svc) => (
          <div class="premium-card group">

            <!-- Imagen de fondo: SOLO esta escala en hover -->
            <div
              class="card-bg"
              style={`background-image: url('${svc.img}')`}
              role="img"
              aria-label={svc.imgAlt}
            ></div>

            <!-- Overlay oscuro: SIN transición, siempre fijo -->
            <div class="card-overlay" aria-hidden="true"></div>

            <!-- Número Liquid Glass: posición absoluta desde la tarjeta -->
            <span class="tag-number">{svc.num}</span>

            <!-- Bloque de texto -->
            <div class="card-content">
              <h3 class="card-title">{svc.title}</h3>
              <p class="card-desc">{svc.desc}</p>
            </div>

            <!-- Recorte orgánico + botón -->
            <div class="cutout-wrapper">
              <div class="inverse-curve-x"></div>
              <div class="inverse-curve-y"></div>
              <a href={svc.href} class="action-btn">
                {t.viewMore}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </div>
        ))}
      </div>

    </div>

    <!-- Mobile: view all -->
    <div class="mt-10 text-center sm:hidden">
      <a href={t.viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold"
        style="color: var(--color-trust);">
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════
     Premium Card — contenedor
  ═══════════════════════════════════════ */
  .premium-card {
    position: relative;
    width: 100%;
    height: 360px;
    border-radius: 22px;
    /* overflow: visible — permite que el cutout-wrapper no sea clippeado */
    overflow: visible;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background-color: #1a1a2e; /* fallback mientras carga imagen */
  }

  /* ═══════════════════════════════════════
     Imagen de fondo
     Solo esta capa hace zoom en hover
  ═══════════════════════════════════════ */
  .card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    border-radius: 22px;   /* clip propio — no depende del padre */
    overflow: hidden;
    z-index: 0;
    transition: transform 0.4s ease;
  }

  .premium-card:hover .card-bg {
    transform: scale(1.05);
  }

  /* ═══════════════════════════════════════
     Overlay oscuro — SIN transición
     Se queda absolutamente fijo
  ═══════════════════════════════════════ */
  .card-overlay {
    position: absolute;
    inset: 0;
    border-radius: 22px;   /* coincide con .card-bg */
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 70%);
    z-index: 1;
    /* Sin transition — no se mueve con la imagen */
  }

  /* ═══════════════════════════════════════
     Número Liquid Glass
     Anclado a la esquina superior-izquierda
     de la tarjeta (relativo a .premium-card)
  ═══════════════════════════════════════ */
  .tag-number {
    position: absolute;
    top: 24px;
    left: 24px;
    z-index: 10;
    display: inline-block;
    background: rgba(255,255,255,0.20);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.30);
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255,255,255,0.95);
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .premium-card:hover .tag-number {
    background: rgba(255,255,255,0.30);
    transform: translateY(-2px);
  }

  /* ═══════════════════════════════════════
     Bloque de texto
  ═══════════════════════════════════════ */
  .card-content {
    position: relative;
    z-index: 2;
    padding: 32px 24px 48px 24px;
    padding-right: 150px;   /* espacio para cutout-wrapper */
    color: white;
  }

  .card-title {
    margin-top: 24px;       /* separación visual del número (que está fuera del flujo) */
    margin-bottom: 10px;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: white;
  }

  .card-desc {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.5;
    color: rgba(255,255,255,0.80);
    max-height: 64px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  /* ═══════════════════════════════════════
     Cutout — caja blanca con curvas inversas
  ═══════════════════════════════════════ */
  .cutout-wrapper {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 172px;
    height: 87px;
    background-color: #ffffff;
    border-top-left-radius: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
  }

  /* Curva inversa: esquina superior-derecha del recorte */
  .inverse-curve-y {
    position: absolute;
    top: -26px;
    right: 0;
    width: 26px;
    height: 26px;
    background-color: transparent;
    border-bottom-right-radius: 26px;
    box-shadow: 0 26px 0 0 #ffffff;
  }

  /* Curva inversa: esquina inferior-izquierda del recorte */
  .inverse-curve-x {
    position: absolute;
    bottom: 0;
    left: -26px;
    width: 26px;
    height: 26px;
    background-color: transparent;
    border-bottom-right-radius: 26px;
    box-shadow: 26px 0 0 0 #ffffff;
  }

  /* ═══════════════════════════════════════
     Botón verde
  ═══════════════════════════════════════ */
  .action-btn {
    background-color: var(--color-green);
    color: white;
    text-decoration: none;
    padding: 12px 20px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.875rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 4px 12px rgba(0, 201, 167, 0.30);
    transition: background-color 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .action-btn:hover {
    background-color: var(--color-green-hover);
    transform: scale(1.04);
  }

  /* Icono: círculo blanco con flecha verde */
  .action-btn svg {
    background: white;
    color: var(--color-green);
    border-radius: 50%;
    padding: 3px;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .card-bg,
    .tag-number,
    .action-btn {
      transition: none !important;
    }
    .premium-card:hover .card-bg,
    .premium-card:hover .tag-number,
    .action-btn:hover {
      transform: none !important;
    }
  }
</style>
