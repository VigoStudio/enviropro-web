---
/**
 * ServicesSection.astro — Grid híbrido:
 *   Col 1 (lg): Tarjeta azul con steps + CTA (Water Damage)
 *   Cols 2–3 (lg): Grid 2×2 con tarjetas de imagen y botón cápsula flotante
 */
import { emergencyPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const imgs = {
  mold:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_640,c_fill,f_auto,q_auto/v1779853414/mold1_iuqg9y.jpg',
  fire:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_640,c_fill,f_auto,q_auto/v1779853304/fireandsmoke_orcmkk.jpg',
  hurricane: 'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_640,c_fill,f_auto,q_auto/v1779853304/hurricane_jozczp.jpg',
  windows:   'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_640,c_fill,f_auto,q_auto/v1779853304/safetywindow_rfsksm.jpg',
};

const t = {
  en: {
    sectionTitle: 'Restoration Services',
    viewAll: 'View all services',
    viewAllHref: '/services',
    viewMore: 'View more',
    featured: {
      num: '01',
      title: 'Water Damage Restoration',
      desc: 'Pipe bursts, flooding, storm water — the clock starts the moment water enters your property. We aim to be on-site in under 60 minutes.',
      steps: ['Emergency dispatch', 'Water extraction', 'Structural drying', 'Full restoration'],
      cta: `Call ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Mold Removal',      desc: 'IICRC-certified inspection, containment, and full remediation.',                href: '/services/mold-removal',        img: imgs.mold,      imgAlt: 'Mold remediation in progress' },
      { num: '03', title: 'Fire & Smoke',       desc: 'Structure cleaning, odor removal, and direct insurance coordination.',          href: '/services/fire-damage',         img: imgs.fire,      imgAlt: 'Fire and smoke damage restoration' },
      { num: '04', title: 'Hurricane Response', desc: 'Roof tarping, water extraction, and rapid mold prevention.',                   href: '/services/hurricane-emergency', img: imgs.hurricane, imgAlt: 'Hurricane damage response' },
      { num: '05', title: 'Impact Windows',     desc: 'Hurricane-rated installation eligible for insurance premium discounts.',        href: '/services/impact-windows',      img: imgs.windows,   imgAlt: 'Impact-resistant window installation' },
    ],
  },
  es: {
    sectionTitle: 'Servicios de Restauración',
    viewAll: 'Ver todos los servicios',
    viewAllHref: '/es/servicios',
    viewMore: 'Ver más',
    featured: {
      num: '01',
      title: 'Restauración por Daños de Agua',
      desc: 'Tuberías rotas, inundaciones, agua de tormenta — el reloj comienza cuando el agua entra a tu propiedad. Llegamos en menos de 60 minutos.',
      steps: ['Despacho de emergencia', 'Extracción de agua', 'Secado estructural', 'Restauración completa'],
      cta: `Llamar ${emergencyPhone.display}`,
      ctaHref: `tel:${emergencyPhone.e164}`,
    },
    secondary: [
      { num: '02', title: 'Eliminación de Moho',  desc: 'Inspección, contención y remediación certificada por IICRC.',              href: '/es/servicios/moho',             img: imgs.mold,      imgAlt: 'Remediación de moho en progreso' },
      { num: '03', title: 'Incendio y Humo',       desc: 'Limpieza estructural, eliminación de olores y coordinación con seguros.',  href: '/es/servicios/incendio',         img: imgs.fire,      imgAlt: 'Restauración por daños de incendio' },
      { num: '04', title: 'Respuesta a Huracanes', desc: 'Cubierta de techos, extracción de agua y prevención rápida de moho.',     href: '/es/servicios/huracanes',        img: imgs.hurricane, imgAlt: 'Respuesta a daños por huracán' },
      { num: '05', title: 'Ventanas de Impacto',   desc: 'Instalación resistente a huracanes con descuentos en primas de seguro.',  href: '/es/servicios/ventanas-impacto', img: imgs.windows,   imgAlt: 'Instalación de ventanas de impacto' },
    ],
  },
}[lang];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">

    <!-- Section header -->
    <div class="flex items-center justify-between mb-10 lg:mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 leading-tight">
        {t.sectionTitle}
      </h2>
      <a
        href={t.viewAllHref}
        class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold shrink-0 ml-4 transition-opacity hover:opacity-70"
        style="color: var(--color-trust);"
      >
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- ── Hybrid grid ── -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">

      <!-- ══════════════════════════════════════════════
           Card 01 — Azul featured (col 1, full height)
           ══════════════════════════════════════════════ -->
      <article
        aria-label={t.featured.title}
        class="group flex flex-col h-full rounded-3xl p-8 cursor-pointer
               transition-all duration-300 ease-in-out
               hover:-translate-y-1 hover:shadow-2xl"
        style="background: var(--color-trust); min-height: 500px;"
      >
        <!-- Number -->
        <span class="text-xs font-bold tracking-widest text-white/50 mb-5 block">
          {t.featured.num}
        </span>

        <!-- Title -->
        <h3 class="text-2xl lg:text-3xl font-bold text-white leading-snug mb-4"
          style="font-family: var(--font-display);">
          {t.featured.title}
        </h3>

        <!-- Description -->
        <p class="text-white/80 text-sm lg:text-base leading-relaxed mb-6">
          {t.featured.desc}
        </p>

        <!-- Steps — flex-1 pushes CTA to bottom -->
        <ul class="flex flex-col gap-3 flex-1">
          {t.featured.steps.map((step, i) => (
            <li class="flex items-center gap-3">
              <span
                class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold"
                style="background: rgba(255,255,255,0.22); color: var(--color-trust);"
              >
                {i + 1}
              </span>
              <span class="text-sm text-white/90">{step}</span>
            </li>
          ))}
        </ul>

        <!-- CTA — green call button, pinned to bottom -->
        <div class="mt-auto pt-8">
          <a
            href={t.featured.ctaHref}
            class="flex items-center justify-center gap-2 w-full
                   text-white font-bold py-3 px-6 rounded-xl text-sm transition-all
                   hover:opacity-90 hover:shadow-lg"
            style="background: var(--color-green);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {t.featured.cta}
          </a>
        </div>
      </article>

      <!-- ══════════════════════════════════════════════
           Cards 02–05 — Imagen + botón cápsula flotante
           ══════════════════════════════════════════════ -->
      <div class="lg:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-6 pb-7">
        {t.secondary.map((svc) => (
          <div class="group relative rounded-3xl overflow-visible shadow-md"
            style="height: 320px;">

            <!-- Contenedor imagen (overflow-hidden independiente) -->
            <div class="absolute inset-0 rounded-3xl overflow-hidden">
              <img
                src={svc.img}
                alt={svc.imgAlt}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
              />
            </div>

            <!-- Overlay degradado -->
            <div
              class="absolute inset-0 rounded-3xl"
              style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.22) 55%, rgba(0,0,0,0.05) 100%);"
              aria-hidden="true"
            />

            <!-- Texto (bottom-left, deja espacio a la derecha para el botón) -->
            <div class="absolute bottom-8 left-6 right-28 z-10">
              <span class="text-xs font-bold uppercase tracking-widest mb-1.5 block"
                style="color: rgba(255,255,255,0.55);">
                {svc.num}
              </span>
              <h3 class="text-white text-lg font-bold leading-snug mb-1.5">
                {svc.title}
              </h3>
              <p class="text-sm line-clamp-2" style="color: rgba(255,255,255,0.75);">
                {svc.desc}
              </p>
            </div>

            <!-- Botón cápsula flotante (sobresale por abajo) -->
            <a
              href={svc.href}
              class="absolute bottom-[-22px] right-6 z-20
                     inline-flex items-center gap-2
                     px-5 py-2.5 rounded-full
                     text-white text-sm font-bold
                     shadow-xl border-2 border-white
                     transition-all duration-200 hover:scale-105 hover:shadow-2xl"
              style="background: var(--color-green);"
            >
              {t.viewMore}
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

          </div>
        ))}
      </div>

    </div>

    <!-- Mobile: view all -->
    <div class="mt-10 text-center sm:hidden">
      <a href={t.viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold"
        style="color: var(--color-trust);">
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* Reduced motion: desactiva zoom de imagen sin quitar el hover state */
  @media (prefers-reduced-motion: reduce) {
    .group img {
      transition: none !important;
    }
    .group:hover img {
      transform: none !important;
    }
  }
</style>
