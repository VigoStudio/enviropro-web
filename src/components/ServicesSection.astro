---
/**
 * ServicesSection.astro — Bento Cards con imagen de fondo.
 * Row 1: Card 01 (2 cols) + Card 02 (1 col)
 * Row 2: Card 03 + Card 04 + Card 05 (1 col cada una)
 */

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

// Cloudinary: c_fill asegura encuadre, f_auto+q_auto optimizan formato y compresión
const imgs = {
  water:     'https://res.cloudinary.com/dxdibfgvw/image/upload/w_1200,h_800,c_fill,f_auto,q_auto/v1779848047/GettyImages-1399919975_1_j9bdot.jpg',
  mold:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_800,c_fill,f_auto,q_auto/v1779853414/mold1_iuqg9y.jpg',
  fire:      'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_800,c_fill,f_auto,q_auto/v1779853304/fireandsmoke_orcmkk.jpg',
  hurricane: 'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_800,c_fill,f_auto,q_auto/v1779853304/hurricane_jozczp.jpg',
  windows:   'https://res.cloudinary.com/dxdibfgvw/image/upload/w_800,h_800,c_fill,f_auto,q_auto/v1779853304/safetywindow_rfsksm.jpg',
};

const t = {
  en: {
    sectionTitle: 'Restoration Services',
    viewAll: 'View all services',
    viewAllHref: '/services',
    viewMore: 'View more',
    services: [
      {
        num: '01',
        title: 'Water Damage Restoration',
        desc: 'Pipe bursts, flooding, storm water — rapid on-site response in under 60 minutes.',
        href: '/services/water-damage',
        img: imgs.water,
        imgAlt: 'Water damage flooding emergency',
        featured: true,
      },
      {
        num: '02',
        title: 'Mold Removal',
        desc: 'IICRC-certified inspection, containment, and full remediation.',
        href: '/services/mold-removal',
        img: imgs.mold,
        imgAlt: 'Mold remediation in progress',
        featured: false,
      },
      {
        num: '03',
        title: 'Fire & Smoke',
        desc: 'Structure cleaning, odor removal, and direct insurance coordination.',
        href: '/services/fire-damage',
        img: imgs.fire,
        imgAlt: 'Fire and smoke damage restoration',
        featured: false,
      },
      {
        num: '04',
        title: 'Hurricane Response',
        desc: 'Roof tarping, water extraction, and rapid mold prevention.',
        href: '/services/hurricane-emergency',
        img: imgs.hurricane,
        imgAlt: 'Hurricane damage emergency response',
        featured: false,
      },
      {
        num: '05',
        title: 'Impact Windows',
        desc: 'Hurricane-rated installation eligible for insurance premium discounts.',
        href: '/services/impact-windows',
        img: imgs.windows,
        imgAlt: 'Impact-resistant window installation',
        featured: false,
      },
    ],
  },
  es: {
    sectionTitle: 'Servicios de Restauración',
    viewAll: 'Ver todos los servicios',
    viewAllHref: '/es/servicios',
    viewMore: 'Ver más',
    services: [
      {
        num: '01',
        title: 'Restauración por Daños de Agua',
        desc: 'Tuberías rotas, inundaciones, tormenta — llegamos en menos de 60 minutos.',
        href: '/es/servicios/moho',
        img: imgs.water,
        imgAlt: 'Emergencia de inundación por daño de agua',
        featured: true,
      },
      {
        num: '02',
        title: 'Eliminación de Moho',
        desc: 'Inspección, contención y remediación certificada por IICRC.',
        href: '/es/servicios/moho',
        img: imgs.mold,
        imgAlt: 'Remediación de moho en progreso',
        featured: false,
      },
      {
        num: '03',
        title: 'Incendio y Humo',
        desc: 'Limpieza estructural, eliminación de olores y coordinación con seguros.',
        href: '/es/servicios/incendio',
        img: imgs.fire,
        imgAlt: 'Restauración por daños de incendio y humo',
        featured: false,
      },
      {
        num: '04',
        title: 'Respuesta a Huracanes',
        desc: 'Cubierta de techos, extracción de agua y prevención rápida de moho.',
        href: '/es/servicios/huracanes',
        img: imgs.hurricane,
        imgAlt: 'Respuesta a emergencia por huracán',
        featured: false,
      },
      {
        num: '05',
        title: 'Ventanas de Impacto',
        desc: 'Instalación resistente a huracanes con descuentos en primas de seguro.',
        href: '/es/servicios/ventanas-impacto',
        img: imgs.windows,
        imgAlt: 'Instalación de ventanas de impacto',
        featured: false,
      },
    ],
  },
}[lang];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-6xl mx-auto px-5 lg:px-8">

    <!-- Section header -->
    <div class="flex items-center justify-between mb-10 lg:mb-12">
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 leading-tight">
        {t.sectionTitle}
      </h2>
      <a
        href={t.viewAllHref}
        class="hidden sm:inline-flex items-center gap-2 text-sm font-semibold shrink-0 ml-4 transition-opacity hover:opacity-70"
        style="color: var(--color-trust);"
        aria-label={t.viewAll}
      >
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Bento grid -->
    <div class="bento-grid">
      {t.services.map((svc) => (
        <a
          href={svc.href}
          aria-label={svc.title}
          class:list={[
            'bento-card group relative overflow-hidden rounded-3xl cursor-pointer',
            svc.featured ? 'bento-featured' : '',
          ]}
        >
          <!-- Background image -->
          <div
            class="absolute inset-0 bg-cover bg-center transition-transform duration-500 ease-out group-hover:scale-110"
            style={`background-image: url('${svc.img}');`}
            role="img"
            aria-label={svc.imgAlt}
          />

          <!-- Gradient overlay -->
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.38) 55%, rgba(0,0,0,0.10) 100%);"
            aria-hidden="true"
          />

          <!-- Content -->
          <div class="relative z-10 h-full flex flex-col justify-end p-6 md:p-8">

            <!-- Service number -->
            <span class="text-xs font-semibold tracking-widest mb-3 block"
              style="color: rgba(255,255,255,0.55);">
              {svc.num}
            </span>

            <!-- Title -->
            <h3 class:list={[
              'font-bold text-white leading-snug mb-3',
              svc.featured ? 'text-2xl md:text-3xl' : 'text-xl md:text-2xl',
            ]}>
              {svc.title}
            </h3>

            <!-- Description -->
            <p class="text-sm leading-relaxed mb-6 line-clamp-2"
              style="color: rgba(255,255,255,0.78);">
              {svc.desc}
            </p>

            <!-- CTA pill -->
            <div>
              <span
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200 group-hover:gap-3"
                style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.30); backdrop-filter: blur(8px);"
              >
                {t.viewMore}
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </span>
            </div>

          </div>
        </a>
      ))}
    </div>

    <!-- Mobile: view all -->
    <div class="mt-8 text-center sm:hidden">
      <a href={t.viewAllHref}
        class="inline-flex items-center gap-2 text-sm font-semibold"
        style="color: var(--color-trust);">
        {t.viewAll}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  /* ── Base card height ── */
  .bento-card {
    height: 384px; /* h-96 */
  }

  /* ── Grid: 1 col mobile ── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  /* ── Tablet: 2 cols · featured spans both ── */
  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .bento-featured {
      grid-column: 1 / -1;
    }
  }

  /* ── Desktop: 3 cols · featured spans 2 ── */
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .bento-featured {
      grid-column: span 2;
    }
  }

  /* ── Respect prefers-reduced-motion ── */
  @media (prefers-reduced-motion: reduce) {
    .bento-card > div:first-child {
      transition: none !important;
    }
    .bento-card:hover > div:first-child {
      transform: none !important;
    }
  }
</style>
