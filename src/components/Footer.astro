---
/**
 * Footer.astro — Diseño moderno slate-950 · bilingüe · datos desde business.ts
 */
import { business, emergencyPhone, miamiPhone, browardPhone, orlandoPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const certLogos = [
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/home-advisor_white_y1zorp.webp',
    alt: lang === 'en' ? 'HomeAdvisor Screened & Approved' : 'HomeAdvisor Verificado y Aprobado',
    width: 120,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/bni-logo_rnhpcg.png',
    alt: lang === 'en' ? 'BNI Member' : 'Miembro BNI',
    width: 120,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/businesswhite_c8trqe.png',
    alt: lang === 'en' ? 'Chamber of Commerce Member' : 'Miembro de la Cámara de Comercio',
    width: 140,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/62964af32be59dc55430caad_nq0etx.png',
    alt: lang === 'en' ? 'Better Business Bureau Accredited' : 'Acreditado por Better Business Bureau',
    width: 120,
    height: 48,
  },
];

const t = {
  en: {
    tagline: '36 years restoring South Florida homes — 24/7 emergency response.',
    certTitle: 'Trusted & Certified Professionals',
    emergency: '24/7 Emergency',
    services: 'Services',
    coverage: 'Coverage',
    company: 'Company',
    serviceList: [
      { label: 'Water Damage Restoration', href: '/services/water-damage' },
      { label: 'Mold Removal & Remediation', href: '/services/mold-removal' },
      { label: 'Fire & Smoke Damage', href: '/services/fire-damage' },
      { label: 'Hurricane Emergency', href: '/services/hurricane-emergency' },
      { label: 'Impact Windows & Doors', href: '/services/impact-windows' },
    ],
    companyList: [
      { label: 'About Us', href: '/about' },
      { label: 'Projects', href: '/projects' },
      { label: 'Contact', href: '/contact' },
      { label: 'Privacy Policy', href: '/privacy' },
    ],
    rights: 'All rights reserved.',
    license: 'Licensed & Insured · IICRC Certified',
    designedBy: 'Designed by',
    privacy: 'Privacy',
    terms: 'Terms',
    sitemap: 'Sitemap',
  },
  es: {
    tagline: '36 años restaurando hogares en South Florida — emergencias 24/7.',
    certTitle: 'Profesionales de Confianza y Certificados',
    emergency: 'Emergencias 24/7',
    services: 'Servicios',
    coverage: 'Cobertura',
    company: 'Empresa',
    serviceList: [
      { label: 'Daños por Agua', href: '/es/servicios/danos-por-agua' },
      { label: 'Remoción de Moho', href: '/es/servicios/remocion-de-moho' },
      { label: 'Daños por Fuego y Humo', href: '/es/servicios/danos-por-fuego' },
      { label: 'Emergencia de Huracán', href: '/es/servicios/emergencia-huracan' },
      { label: 'Ventanas de Impacto', href: '/es/servicios/ventanas-de-impacto' },
    ],
    companyList: [
      { label: 'Nosotros', href: '/es/nosotros' },
      { label: 'Proyectos', href: '/es/proyectos' },
      { label: 'Contacto', href: '/es/contacto' },
      { label: 'Política de Privacidad', href: '/es/privacidad' },
    ],
    rights: 'Todos los derechos reservados.',
    license: 'Licenciado y Asegurado · Certificado IICRC',
    designedBy: 'Diseñado por',
    privacy: 'Privacidad',
    terms: 'Términos',
    sitemap: 'Sitemap',
  },
}[lang];

const year = new Date().getFullYear();
---

<footer class="bg-slate-950 text-white border-t border-white/10">
  <div class="container-x py-16 md:py-20">

    <!-- ── Certificaciones ── -->
    <div class="mb-14">
      <p class="text-center text-xs font-semibold uppercase tracking-widest mb-8"
        style="color: rgba(255,255,255,0.38); letter-spacing: 0.12em;">
        {t.certTitle}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
        {certLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.alt}
            width={logo.width}
            height={logo.height}
            loading="lazy"
            decoding="async"
            class="h-10 md:h-12 w-auto object-contain opacity-70 hover:opacity-100 transition-opacity duration-300"
          />
        ))}
      </div>
    </div>

    <!-- ── Divider ── -->
    <div class="border-t border-white/8 mb-12"></div>

    <!-- ── Grid principal ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 mb-14">

      <!-- Columna 1: Brand -->
      <div>
        <a href={lang === 'en' ? '/' : '/es/'} aria-label={business.brandName} class="inline-block mb-6">
          <img
            src="/images/logos/enviro-pro-white.png"
            alt={business.brandName}
            width="150"
            height="48"
            loading="lazy"
            decoding="async"
            class="h-7 md:h-12 w-auto object-contain"
          />
        </a>
        <p class="text-sm leading-relaxed mb-6" style="color: rgba(255,255,255,0.65);">
          {t.tagline}
        </p>
        <div>
          <p class="text-xs uppercase tracking-wider mb-1.5" style="color: rgba(255,255,255,0.45);">
            {t.emergency}
          </p>
          <a
            href={`tel:${emergencyPhone.e164}`}
            class="text-xl font-bold hover:opacity-80 transition-opacity"
            style="color: var(--color-green);"
          >
            {emergencyPhone.display}
          </a>
        </div>
      </div>

      <!-- Columna 2: Services -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-5"
          style="color: rgba(255,255,255,0.50);">
          {t.services}
        </h4>
        <ul class="space-y-3">
          {t.serviceList.map((s) => (
            <li>
              <a href={s.href}
                class="text-sm transition-colors duration-200 hover:text-white"
                style="color: rgba(255,255,255,0.65);">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Coverage -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-5"
          style="color: rgba(255,255,255,0.50);">
          {t.coverage}
        </h4>
        <ul class="space-y-4">
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color: rgba(255,255,255,0.38);">
              Miami-Dade
            </p>
            <a href={`tel:${miamiPhone.e164}`}
              class="text-sm transition-colors duration-200 hover:text-white"
              style="color: rgba(255,255,255,0.65);">
              {miamiPhone.display}
            </a>
          </li>
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color: rgba(255,255,255,0.38);">
              Broward
            </p>
            <a href={`tel:${browardPhone.e164}`}
              class="text-sm transition-colors duration-200 hover:text-white"
              style="color: rgba(255,255,255,0.65);">
              {browardPhone.display}
            </a>
          </li>
          <li>
            <p class="text-xs uppercase tracking-wider mb-0.5" style="color: rgba(255,255,255,0.38);">
              Orlando
            </p>
            <a href={`tel:${orlandoPhone.e164}`}
              class="text-sm transition-colors duration-200 hover:text-white"
              style="color: rgba(255,255,255,0.65);">
              {orlandoPhone.display}
            </a>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Company + Address -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest mb-5"
          style="color: rgba(255,255,255,0.50);">
          {t.company}
        </h4>
        <ul class="space-y-3 mb-6">
          {t.companyList.map((c) => (
            <li>
              <a href={c.href}
                class="text-sm transition-colors duration-200 hover:text-white"
                style="color: rgba(255,255,255,0.65);">
                {c.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="pt-5 border-t border-white/10">
          <address class="not-italic text-sm leading-relaxed" style="color: rgba(255,255,255,0.50);">
            {business.address.street}<br />
            {business.address.city}, {business.address.state} {business.address.zip}
          </address>
        </div>
      </div>

    </div>

    <!-- ── Bottom bar ── -->
    <div class="border-t border-white/10 pt-7 flex flex-col md:flex-row justify-between items-center gap-5">

      <!-- Copyright + license -->
      <p class="text-xs text-center md:text-left" style="color: rgba(255,255,255,0.40);">
        © {year} {business.legalName}. {t.rights}<br class="sm:hidden" />
        <span class="hidden sm:inline"> · </span>{t.license}
      </p>

      <!-- Legal links + VigoStudio -->
      <div class="flex items-center gap-5 flex-wrap justify-center">
        <a href={lang === 'en' ? '/privacy' : '/es/privacidad'}
          class="text-xs transition-colors duration-200 hover:text-white"
          style="color: rgba(255,255,255,0.40);">
          {t.privacy}
        </a>
        <span style="color: rgba(255,255,255,0.15);" aria-hidden="true">·</span>
        <a href={lang === 'en' ? '/sitemap' : '/es/sitemap'}
          class="text-xs transition-colors duration-200 hover:text-white"
          style="color: rgba(255,255,255,0.40);">
          {t.sitemap}
        </a>
        <span style="color: rgba(255,255,255,0.15);" aria-hidden="true">·</span>
        <!-- VigoStudio credit -->
        <a
          href="https://www.vigostudio.io"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="VigoStudio — Web Design Agency"
          class="flex items-center gap-1.5 opacity-40 hover:opacity-80 transition-opacity duration-200"
        >
          <span class="text-xs" style="color: rgba(255,255,255,0.9);">{t.designedBy}</span>
          <img
            src="https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917480/logo-vigostudio-white_zqxhdn.png"
            alt="VigoStudio"
            width="90"
            height="20"
            loading="lazy"
            decoding="async"
            class="h-4 w-auto object-contain"
          />
        </a>
      </div>

    </div>
  </div>
</footer>
