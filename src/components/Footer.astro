---
/**
 * Footer.astro — NAP completo, redes, certificaciones, copyright.
 */
import { business, emergencyPhone, miamiPhone, browardPhone, orlandoPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;

const certLogos = [
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/home-advisor_white_y1zorp.webp',
    alt: lang === 'en' ? 'HomeAdvisor Screened & Approved' : 'HomeAdvisor Verificado y Aprobado',
    width: 120,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/bni-logo_rnhpcg.png',
    alt: lang === 'en' ? 'BNI Member' : 'Miembro BNI',
    width: 120,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/businesswhite_c8trqe.png',
    alt: lang === 'en' ? 'Chamber of Commerce Member' : 'Miembro de la Cámara de Comercio',
    width: 140,
    height: 48,
  },
  {
    src: 'https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917205/62964af32be59dc55430caad_nq0etx.png',
    alt: lang === 'en' ? 'Better Business Bureau Accredited' : 'Acreditado por Better Business Bureau',
    width: 120,
    height: 48,
  },
];

const t = {
  en: {
    tagline: '36 years restoring South Florida homes — 24/7 emergency response.',
    services: 'Services',
    coverage: 'Coverage',
    company: 'Company',
    serviceList: [
      { label: 'Water Damage Restoration', href: '/services/water-damage' },
      { label: 'Mold Removal & Remediation', href: '/services/mold-removal' },
      { label: 'Fire & Smoke Damage', href: '/services/fire-damage' },
      { label: 'Hurricane Emergency', href: '/services/hurricane-emergency' },
      { label: 'Impact Windows & Doors', href: '/services/impact-windows' },
    ],
    companyList: [
      { label: 'About Us', href: '/about' },
      { label: 'Projects', href: '/projects' },
      { label: 'Contact', href: '/contact' },
      { label: 'Privacy Policy', href: '/privacy' },
    ],
    emergency: '24/7 Emergency',
    rights: 'All rights reserved.',
    license: 'Licensed & Insured · IICRC Certified',
  },
  es: {
    tagline: '36 años restaurando hogares en South Florida — emergencias 24/7.',
    services: 'Servicios',
    coverage: 'Cobertura',
    company: 'Empresa',
    serviceList: [
      { label: 'Daños por Agua', href: '/es/servicios/danos-por-agua' },
      { label: 'Remoción de Moho', href: '/es/servicios/remocion-de-moho' },
      { label: 'Daños por Fuego y Humo', href: '/es/servicios/danos-por-fuego' },
      { label: 'Emergencia de Huracán', href: '/es/servicios/emergencia-huracan' },
      { label: 'Ventanas de Impacto', href: '/es/servicios/ventanas-de-impacto' },
    ],
    companyList: [
      { label: 'Nosotros', href: '/es/nosotros' },
      { label: 'Proyectos', href: '/es/proyectos' },
      { label: 'Contacto', href: '/es/contacto' },
      { label: 'Política de Privacidad', href: '/es/privacidad' },
    ],
    emergency: 'Emergencias 24/7',
    rights: 'Todos los derechos reservados.',
    license: 'Licenciado y Asegurado · Certificado IICRC',
  },
}[lang];

const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-ink)] text-white">
  <div class="container-x section-y">

    <!-- Top grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand + tagline + emergency -->
      <div class="space-y-4">
        <h3 class="text-2xl font-bold" style="font-family: var(--font-display)">{business.brandName}</h3>
        <p class="text-sm opacity-80 leading-relaxed">{t.tagline}</p>

        <div class="pt-2">
          <p class="text-xs uppercase tracking-wider opacity-60 mb-1">{t.emergency}</p>
          <a
            href={`tel:${emergencyPhone.e164}`}
            class="text-xl font-bold hover:underline"
            style="color: var(--color-emergency)"
          >
            {emergencyPhone.display}
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 opacity-90">{t.services}</h4>
        <ul class="space-y-2">
          {t.serviceList.map((s) => (
            <li>
              <a href={s.href} class="text-sm opacity-80 hover:opacity-100 hover:underline transition-opacity">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coverage -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 opacity-90">{t.coverage}</h4>
        <ul class="space-y-2 text-sm">
          <li class="opacity-80">
            <span class="block text-xs uppercase opacity-60">Miami-Dade</span>
            <a href={`tel:${miamiPhone.e164}`} class="hover:underline">{miamiPhone.display}</a>
          </li>
          <li class="opacity-80">
            <span class="block text-xs uppercase opacity-60">Broward</span>
            <a href={`tel:${browardPhone.e164}`} class="hover:underline">{browardPhone.display}</a>
          </li>
          <li class="opacity-80">
            <span class="block text-xs uppercase opacity-60">Orlando</span>
            <a href={`tel:${orlandoPhone.e164}`} class="hover:underline">{orlandoPhone.display}</a>
          </li>
        </ul>
      </div>

      <!-- Company + address -->
      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider mb-4 opacity-90">{t.company}</h4>
        <ul class="space-y-2 mb-4">
          {t.companyList.map((c) => (
            <li>
              <a href={c.href} class="text-sm opacity-80 hover:opacity-100 hover:underline">
                {c.label}
              </a>
            </li>
          ))}
        </ul>

        <address class="text-sm opacity-70 not-italic leading-relaxed">
          {business.address.street}<br/>
          {business.address.city}, {business.address.state} {business.address.zip}
        </address>
      </div>
    </div>

    <!-- Certification logos -->
    <div class="mt-12 pt-10 border-t border-white/10">
      <p class="text-center text-xs font-semibold uppercase tracking-widest mb-8"
        style="color: rgba(255,255,255,0.40); letter-spacing: 0.12em;">
        {lang === 'en' ? 'Trusted & Certified' : 'Confianza y Certificación'}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-14">
        {certLogos.map((logo) => (
          <img
            src={logo.src}
            alt={logo.alt}
            width={logo.width}
            height={logo.height}
            loading="lazy"
            decoding="async"
            class="h-10 md:h-12 w-auto object-contain opacity-60 hover:opacity-90 transition-opacity duration-200"
          />
        ))}
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-xs opacity-60">
        © {year} {business.legalName}. {t.rights} · {t.license}
      </p>

      <!-- Agency credit -->
      <a
        href="https://www.vigostudio.io"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="VigoStudio — Web Design Agency"
        class="flex items-center gap-2 opacity-50 hover:opacity-90 transition-opacity duration-200"
      >
        <span class="text-xs" style="color: rgba(255,255,255,0.5);">
          {lang === 'en' ? 'Designed by' : 'Diseñado por'}
        </span>
        <img
          src="https://res.cloudinary.com/dxdibfgvw/image/upload/f_auto,q_auto/v1779917480/logo-vigostudio-white_zqxhdn.png"
          alt="VigoStudio"
          width="90"
          height="20"
          loading="lazy"
          decoding="async"
          class="h-4 w-auto object-contain"
        />
      </a>
    </div>
  </div>
</footer>
