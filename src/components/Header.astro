---
/**
 * Header.astro — Floating pill nav.
 * Initial : transparent bg, white text.
 * Scrolled: white/90 bg, dark text on nav links, green CTA stays green.
 */
import { emergencyPhone } from '../data/business';

export interface Props {
  lang: 'en' | 'es';
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const nav = {
  en: [
    { label: 'Services',      href: '/services' },
    { label: 'Service Areas', href: '/service-areas' },
    { label: 'About',         href: '/about' },
    { label: 'Contact',       href: '/contact' },
  ],
  es: [
    { label: 'Servicios', href: '/es/servicios' },
    { label: 'Áreas',     href: '/es/areas-de-servicio' },
    { label: 'Nosotros',  href: '/es/nosotros' },
    { label: 'Contacto',  href: '/es/contacto' },
  ],
};

const enToEs: Record<string, string> = {
  '/': '/es/',
  '/services': '/es/servicios',
  '/service-areas': '/es/areas-de-servicio',
  '/about': '/es/nosotros',
  '/contact': '/es/contacto',
};
const esPathKey = currentPath.replace(/\/$/, '') || '/';
const langSwitchUrl = lang === 'en'
  ? (enToEs[currentPath] ?? enToEs[esPathKey] ?? `/es${currentPath}`)
  : (Object.entries(enToEs).find(([, es]) => es === currentPath || es === esPathKey + '/')?.[0] ?? '/');

const ctaFull  = lang === 'en' ? 'Call 24/7' : 'Llamar 24/7';
const menuOpen = lang === 'en' ? 'Open menu' : 'Abrir menú';
---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-3 pt-3 md:px-5 md:pt-4">

    <!-- Floating pill -->
    <div
      id="nav-pill"
      class="flex items-center justify-between gap-3 md:gap-6
             rounded-full px-3 py-2 md:px-5 md:py-2.5
             transition-all duration-300"
    >

      <!-- ① Logo — left -->
      <a href={lang === 'en' ? '/' : '/es/'} class="flex-shrink-0" aria-label="EnviroPro USA">
        <img
          src="/images/logos/enviro-pro-logo.png"
          alt="EnviroPro USA"
          loading="eager"
          class="h-7 md:h-8 w-auto object-contain"
        />
      </a>

      <!-- ② Nav — center (desktop) -->
      <nav class="hidden md:flex items-center gap-4 lg:gap-6 flex-1 justify-center">
        {nav[lang].map((item) => (
          <a
            href={item.href}
            class="nav-link text-sm font-semibold tracking-wide whitespace-nowrap
                   transition-colors hover:opacity-80"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- ③ CTA + lang toggle — right -->
      <div class="flex items-center gap-2 shrink-0">

        <!-- Language toggle — visible on ALL sizes -->
        <a
          href={langSwitchUrl}
          class="lang-link inline-flex items-center text-xs font-bold transition-colors
                 px-2.5 py-1.5 rounded-full"
          style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.20);"
          aria-label={lang === 'en' ? 'Cambiar a español' : 'Switch to English'}
        >
          {lang === 'en' ? 'ES' : 'EN'}
        </a>

        <!-- Call button — hidden on xs, visible sm+ -->
        <a
          href={`tel:${emergencyPhone.e164}`}
          class="hidden sm:inline-flex items-center gap-1.5 rounded-full font-bold text-white
                 px-4 py-2 text-sm whitespace-nowrap transition-all
                 shadow-md hover:shadow-lg hover:scale-105"
          style="background:#00C9A7;"
          onmouseover="this.style.background='#00A38A'"
          onmouseout="this.style.background='#00C9A7'"
          aria-label={`${ctaFull} ${emergencyPhone.display}`}
        >
          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
              d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
          </svg>
          {ctaFull}
        </a>

        <!-- Hamburger (mobile only) -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-1.5 rounded-full transition-colors hamburger-btn"
          aria-label={menuOpen}
          aria-expanded="false"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>

      </div>
    </div>
  </div>

  <!-- Mobile overlay menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden fixed inset-0 z-[60] flex flex-col px-6 pb-8"
    style="background:rgba(5,10,20,0.93); -webkit-backdrop-filter:blur(24px); backdrop-filter:blur(24px);"
  >
    <div class="flex items-center justify-between pt-5 pb-6">
      <img src="/images/logos/enviro-pro-logo.png" alt="EnviroPro" class="h-8 w-auto" />
      <button
        id="mobile-menu-close"
        class="p-2 text-white/70 hover:text-white transition-colors"
        aria-label={lang === 'en' ? 'Close menu' : 'Cerrar menú'}
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <nav class="flex flex-col gap-1 flex-1">
      {nav[lang].map((item) => (
        <a
          href={item.href}
          class="py-4 text-2xl font-semibold text-white/90 hover:text-white border-b border-white/10 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={`tel:${emergencyPhone.e164}`}
      class="btn-emergency text-center text-lg mt-4"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
      </svg>
      {emergencyPhone.display}
    </a>

    <a
      href={langSwitchUrl}
      class="text-center text-sm text-white/40 hover:text-white/70 transition-colors mt-3"
    >
      {lang === 'en' ? 'Ver en Español' : 'View in English'}
    </a>
  </div>

</header>

<style>
  /* ── INITIAL STATE: transparent pill, white text ── */
  #nav-pill {
    background: transparent;
    border: 1px solid transparent;
  }

  .nav-link  { color: rgba(255, 255, 255, 0.88); }
  .lang-link { color: rgba(255, 255, 255, 0.90); }
  .hamburger-btn { color: white; }

  /* ── SCROLLED STATE: white glass pill, dark text ── */
  #navbar.scrolled #nav-pill {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(226, 232, 240, 0.80); /* slate-200/80 */
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.10);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    backdrop-filter: blur(20px) saturate(1.8);
  }

  #navbar.scrolled .nav-link  { color: #0f172a; } /* slate-900 */
  #navbar.scrolled .lang-link {
    color: #0f172a;
    background: rgba(15, 23, 42, 0.08) !important;
    border-color: rgba(15, 23, 42, 0.15) !important;
  }
  #navbar.scrolled .hamburger-btn { color: #0f172a; }

  #navbar.scrolled .nav-link:hover  { color: #00A38A; opacity: 1; }
  #navbar.scrolled .lang-link:hover { color: #00A38A; }
</style>

<script>
  const navbar   = document.getElementById('navbar');
  const btn      = document.getElementById('mobile-menu-btn');
  const menu     = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');

  // Scroll → white pill
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });

  function openMenu()  {
    menu?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  btn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach(l => l.addEventListener('click', closeMenu));
</script>
